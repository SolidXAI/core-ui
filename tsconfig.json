{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "useDefineForClassFields": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noEmit": false,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": false,
    "moduleDetection": "force",
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": false,
    "outDir": "./dist",               // Output directory for compiled files
    "rootDir": "./src",               // Root directory for source files
    "declaration": true,              // Generate TypeScript declaration files (.d.ts)
    "declarationMap": true,           // Generate declaration maps for debugging
    "emitDeclarationOnly": false,
    "declarationDir": "dist",
    "sourceMap": true,                // Generate source maps for debugging
    "inlineSources": true,            // Embed sources in sourcemaps for browser debugging
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "./src/**/*",
    "./types/**/*.d.ts",
  ],
  "exclude": ["node_modules","dist"],
}
